{
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?!ajmalmubarak\\.in).*\\.vercel\\.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noimageindex"
        }
      ]
    }
  ]
}
